# kBuddhi AI — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# These values are OUTPUT by `cdk deploy` and baked into config.js automatically.
# You do NOT need to set them manually unless running locally.
# For local development, copy this file to .env.local and fill in the values
# from your CDK stack outputs.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Region ────────────────────────────────────────────────────────────────
AWS_REGION=us-east-2

# ── Amazon Cognito ───────────────────────────────────────────────────────────
# Obtain from: cdk deploy output → CognitoUserPoolId / CognitoClientId
# Or: AWS Console → Cognito → User Pools → kbuddhiai-users
COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── API Gateway ──────────────────────────────────────────────────────────────
# Obtain from: cdk deploy output → ApiGatewayUrl
# Format: https://<id>.execute-api.us-east-2.amazonaws.com/prod
API_BASE_URL=https://XXXXXXXXXX.execute-api.us-east-2.amazonaws.com/prod

# ── S3 Buckets ───────────────────────────────────────────────────────────────
# Obtain from: cdk deploy outputs
STATIC_BUCKET=kbuddhiai-static-699092321120
UPLOADS_BUCKET=kbuddhiai-uploads-699092321120

# ── Amazon SES ───────────────────────────────────────────────────────────────
# Sender address — must be verified in SES
# Domain verification is created automatically by CDK (Route 53 DKIM records)
SES_SENDER=noreply@kbuddhiai.com

# NOTE: SES starts in sandbox mode (emails only reach SES-verified addresses).
# Request production access via:
#   AWS Console → SES → Account dashboard → Request production access
# This is required before real users can receive OTP emails.

# ── OpenRouter (AI chat backend) ─────────────────────────────────────────────
# The chat Lambda uses OpenRouter to call openai/gpt-4o-mini.
# Set this in the Lambda directly (never commit this key to source control):
#   AWS Console → Lambda → kbuddhiai-chat → Configuration → Environment variables
# Or: aws lambda update-function-configuration --function-name kbuddhiai-chat \
#       --environment Variables="{OPENROUTER_API_KEY=sk-or-v1-...}"
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_KEY

# ── Route 53 ─────────────────────────────────────────────────────────────────
# Obtain from: cdk deploy output → HostedZoneId
# Used as context for KbuddhiCertStack: --context hostedZoneId=Z...
HOSTED_ZONE_ID=ZXXXXXXXXXXXXXXXXX

# ── ACM Certificate (us-east-1) ──────────────────────────────────────────────
# Obtain from: cdk deploy KbuddhiCertStack output → CertificateArn
# Used to enable kbuddhiai.com on CloudFront: --context certArn=arn:aws:acm:us-east-1:...
CERT_ARN=arn:aws:acm:us-east-1:699092321120:certificate/REPLACE

# ── Phase 2 (future) ─────────────────────────────────────────────────────────
# Glue job name (already deployed, triggered on-demand)
GLUE_JOB_NAME=kbuddhiai-convert-to-parquet

# Athena database and table (queryable but not wired into the app yet)
ATHENA_DATABASE=kbuddhiai_data
ATHENA_TABLE=uploads
ATHENA_WORKGROUP=kbuddhiai

# FHIR-ready S3 path (for future HealthLake integration)
FHIR_S3_PATH=s3://kbuddhiai-uploads-699092321120/fhir/
